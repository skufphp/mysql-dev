# ==========================================
# MySQL Development Environment
# ==========================================

# --- MySQL Configuration ---
# Пароль root (нужен для первого запуска контейнера)
MYSQL_ROOT_PASSWORD=root_password

# --- phpMyAdmin Configuration ---
# Хост БД для подключения из phpMyAdmin
PMA_HOST=mysql-dev

# --- Ports Configuration (Host -> Container) ---
# Внешний порт для подключения к базе (3306 внутри)
MYSQL_PORT=7033
# Внешний порт для доступа к phpMyAdmin (80 внутри)
PHPMYADMIN_PORT=7034

# --- SQL Commands for Project Setup ---
# -- 1) Пользователь под конкретный проект
# CREATE USER 'proj1_user'@'%' IDENTIFIED BY '<PASSWORD_PLACEHOLDER>';
#
# -- 2) База под проект
# CREATE DATABASE proj1_db;
#
# -- 3) Назначение прав
# GRANT ALL PRIVILEGES ON `proj1_db`.* TO 'proj1_user'@'%';
# FLUSH PRIVILEGES;
#
# -------
# -- Удаление (ОСТОРОЖНО!):
# DROP DATABASE proj1_db;
# DROP USER 'proj1_user'@'%';
