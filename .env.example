# ===========================================
# MySQL Development Environment Configuration
# ===========================================

# MySQL Root Password (используется docker-compose.yml)
MYSQL_ROOT_PASSWORD=root_password

# phpMyAdmin Configuration (используется docker-compose.yml)
PMA_HOST=mysql-dev

# Ports Configuration
MYSQL_PORT=your_port
PHPMYADMIN_PORT=your_port

# MySQL Database Configuration
# База и пользователь создаются вручную через PHPStorm или init.sql
#MYSQL_HOST=mysql-dev
#MYSQL_PORT=your_port
#MYSQL_DATABASE=your-db
#MYSQL_USER=database-user
#MYSQL_PASSWORD=database-user-password

#-- 1) Пользователь под конкретный проект
#CREATE ROLE some_user WITH LOGIN PASSWORD 'some_password';
#
#-- 2) База под проект (ВАЖНО: владелец = этот пользователь)
#CREATE DATABASE your_db OWNER some_user;
#
#-- 3) (рекомендуется) закрыть доступ всем прочим и оставить только владельца
#REVOKE ALL ON DATABASE some_user FROM PUBLIC;
#GRANT CONNECT ON DATABASE your_db TO some_user;
#
#-------
#
#DROP DATABASE your_db;
#-- DROP SCHEMA your_db_schema CASCADE;
#DROP USER some_user;
